# ============================================
# CallCenter SaaS — Environment Variables
# cp .env.example .env  →  dəyərləri doldurun
# ============================================

# Database
DB_PASSWORD=strongpassword_deyisin

# Redis
REDIS_PASSWORD=redispass_deyisin

# JWT
JWT_SECRET=cok_uzun_ve_random_bir_secret_yazin_buraya

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SIP_USER=your_twilio_sip_username

# Zadarma (https://my.zadarma.com)
ZADARMA_USER=your_zadarma_user
ZADARMA_SECRET=your_zadarma_secret

# GoIP GSM Gateway
GOIP_SECRET=goip_sip_password

# Asterisk AMI
ASTERISK_AMI_SECRET=amipassword_deyisin
ASTERISK_SIP_HOST=YOUR_SERVER_IP

# Frontend URL (CORS)
FRONTEND_URL=http://YOUR_SERVER_IP
